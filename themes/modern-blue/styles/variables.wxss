/*
 * 现代简约蓝主题 - CSS 变量定义
 * Theme: modern-blue
 * Version: 1.0.0
 */

/* ==================== 颜色变量 ==================== */

/* 主色调 */
--primary-50: #E6F7FF;
--primary-100: #BAE7FF;
--primary-200: #91D5FF;
--primary-300: #69C0FF;
--primary-400: #40A9FF;
--primary-500: #1890FF;
--primary-600: #096DD9;
--primary-700: #0050B3;
--primary-800: #003A8C;
--primary-900: #002766;
--primary-950: #001529;

/* 中性色 */
--neutral-50: #FAFAFA;
--neutral-100: #F5F5F5;
--neutral-200: #EEEEEE;
--neutral-300: #E0E0E0;
--neutral-400: #BDBDBD;
--neutral-500: #9E9E9E;
--neutral-600: #757575;
--neutral-700: #616161;
--neutral-800: #424242;
--neutral-900: #212121;
--neutral-950: #0A0A0A;

/* 功能色 */
--success: #52C41A;
--success-light: #F6FFED;
--success-dark: #389E0D;
--warning: #FAAD14;
--warning-light: #FFF7E6;
--warning-dark: #D46B08;
--error: #FF4D4F;
--error-light: #FFF1F0;
--error-dark: #CF1322;
--info: #1890FF;
--info-light: #E6F7FF;
--info-dark: #096DD9;
--disabled: #BFBFBF;
--disabled-light: #F5F5F5;
--disabled-dark: #8C8C8C;

/* 背景色 */
--bg-page: #F5F5F5;
--bg-card: #FFFFFF;
--bg-elevated: #FFFFFF;
--bg-sunken: #EEEEEE;
--bg-hover: #FAFAFA;
--bg-pressed: #F0F0F0;
--bg-mask: rgba(0, 0, 0, 0.45);
--bg-mask-light: rgba(0, 0, 0, 0.25);
--bg-overlay: rgba(255, 255, 255, 0.95);

/* 文字色 */
--text-primary: #212121;
--text-secondary: #616161;
--text-tertiary: #9E9E9E;
--text-disabled: #BFBFBF;
--text-inverse: #FFFFFF;
--text-link: #1890FF;
--text-link-hover: #40A9FF;
--text-link-active: #096DD9;

/* 边框色 */
--border-light: #EEEEEE;
--border-default: #E0E0E0;
--border-dark: #BDBDBD;
--border-focus: #1890FF;
--border-error: #FF4D4F;

/* ==================== 字体变量 ==================== */

/* 字体家族 */
--font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', sans-serif;
--font-family-mono: 'SF Mono', Monaco, 'Cascadia Code', 'Fira Code', monospace;

/* 字号 */
--font-size-display: 32px;
--font-size-display-sm: 28px;
--font-size-title: 20px;
--font-size-title-sm: 18px;
--font-size-subtitle: 17px;
--font-size-body: 15px;
--font-size-body-sm: 14px;
--font-size-caption: 13px;
--font-size-caption-sm: 12px;
--font-size-small: 11px;
--font-size-tiny: 10px;

/* 字重 */
--font-weight-thin: 100;
--font-weight-light: 300;
--font-weight-regular: 400;
--font-weight-medium: 500;
--font-weight-semibold: 600;
--font-weight-bold: 700;
--font-weight-heavy: 800;
--font-weight-black: 900;

/* 行高 */
--line-height-tight: 1.25;
--line-height-snug: 1.375;
--line-height-normal: 1.5;
--line-height-relaxed: 1.625;
--line-height-loose: 2;

/* 字间距 */
--letter-spacing-tighter: -0.05em;
--letter-spacing-tight: -0.025em;
--letter-spacing-normal: 0;
--letter-spacing-wide: 0.025em;
--letter-spacing-wider: 0.05em;
--letter-spacing-widest: 0.1em;

/* ==================== 间距变量 ==================== */

--space-unit: 4px;
--space-0: 0;
--space-1: 4px;
--space-2: 8px;
--space-3: 12px;
--space-4: 16px;
--space-5: 20px;
--space-6: 24px;
--space-8: 32px;
--space-10: 40px;
--space-12: 48px;
--space-16: 64px;
--space-20: 80px;
--space-24: 96px;
--space-32: 128px;

/* ==================== 圆角变量 ==================== */

--radius-none: 0;
--radius-xs: 2px;
--radius-sm: 4px;
--radius-md: 8px;
--radius-lg: 12px;
--radius-xl: 16px;
--radius-2xl: 20px;
--radius-3xl: 24px;
--radius-full: 9999px;

/* ==================== 阴影变量 ==================== */

--shadow-none: none;
--shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.03);
--shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
--shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
--shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
--shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
--shadow-2xl: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
--shadow-inner: inset 0 2px 4px rgba(0, 0, 0, 0.06);
--shadow-primary: 0 4px 14px rgba(24, 144, 255, 0.39);
--shadow-primary-sm: 0 2px 8px rgba(24, 144, 255, 0.25);

/* ==================== 动画变量 ==================== */

/* 持续时间 */
--duration-instant: 0ms;
--duration-fast: 100ms;
--duration-normal: 200ms;
--duration-slow: 300ms;
--duration-slower: 500ms;
--duration-slowest: 700ms;

/* 缓动函数 */
--ease-linear: linear;
--ease-in: cubic-bezier(0.4, 0, 1, 1);
--ease-out: cubic-bezier(0, 0, 0.2, 1);
--ease-in-out: cubic-bezier(0.4, 0, 0.2, 1);
--ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
--ease-bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);

/* ==================== 组件变量 ==================== */

/* 按钮 */
--btn-border-radius: 8px;
--btn-height-lg: 48px;
--btn-height-md: 40px;
--btn-height-sm: 32px;
--btn-height-mini: 24px;
--btn-padding-lg: 0 24px;
--btn-padding-md: 0 20px;
--btn-padding-sm: 0 16px;
--btn-padding-mini: 0 8px;
--btn-font-size-lg: 17px;
--btn-font-size-md: 15px;
--btn-font-size-sm: 13px;
--btn-font-size-mini: 11px;
--btn-primary-bg: #1890FF;
--btn-primary-color: #FFFFFF;
--btn-primary-hover-bg: #40A9FF;
--btn-primary-active-bg: #096DD9;
--btn-secondary-bg: transparent;
--btn-secondary-border: #1890FF;
--btn-secondary-color: #1890FF;
--btn-secondary-hover-bg: #E6F7FF;

/* 卡片 */
--card-border-radius: 12px;
--card-bg: #FFFFFF;
--card-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
--card-shadow-hover: 0 4px 12px rgba(0, 0, 0, 0.1);
--card-padding: 16px;
--card-padding-lg: 24px;
--card-padding-sm: 12px;

/* 输入框 */
--input-border-radius: 8px;
--input-height: 44px;
--input-border-color: #E0E0E0;
--input-border-color-focus: #1890FF;
--input-border-color-error: #FF4D4F;
--input-bg: #FFFFFF;
--input-bg-disabled: #F5F5F5;
--input-placeholder-color: #BDBDBD;
--input-padding: 0 12px;
--input-font-size: 15px;

/* 标签 */
--tag-border-radius: 4px;
--tag-padding: 2px 8px;
--tag-font-size: 11px;
--tag-font-weight: 500;
--tag-pending-bg: #FFF7E6;
--tag-pending-color: #D46B08;
--tag-approved-bg: #F6FFED;
--tag-approved-color: #389E0D;
--tag-rejected-bg: #FFF1F0;
--tag-rejected-color: #CF1322;

/* 日历 */
--calendar-day-size: 40px;
--calendar-day-radius: 8px;
--calendar-selected-bg: #1890FF;
--calendar-selected-color: #FFFFFF;
--calendar-today-border: #1890FF;
--calendar-today-color: #1890FF;

/* 时段选择器 */
--timeslot-height: 36px;
--timeslot-border-radius: 6px;
--timeslot-available-border: #1890FF;
--timeslot-available-color: #1890FF;
--timeslot-selected-bg: #1890FF;
--timeslot-selected-color: #FFFFFF;

/* 导航栏 */
--nav-height: 44px;
--nav-bg: #1890FF;
--nav-color: #FFFFFF;
--nav-font-size: 17px;
--nav-font-weight: 600;

/* TabBar */
--tabbar-height: 50px;
--tabbar-bg: #FFFFFF;
--tabbar-border-top: 1px solid #E0E0E0;
--tabbar-color: #9E9E9E;
--tabbar-active-color: #1890FF;
--tabbar-font-size: 10px;
--tabbar-icon-size: 24px;

/* ==================== 布局变量 ==================== */

/* 页面 */
--page-bg: #F5F5F5;
--page-padding: 16px;
--page-max-width: 100%;

/* 安全区域 */
--safe-area-top: env(safe-area-inset-top);
--safe-area-bottom: env(safe-area-inset-bottom);
--safe-area-left: env(safe-area-inset-left);
--safe-area-right: env(safe-area-inset-right);

/* ==================== 状态变量 ==================== */

/* 预约状态 */
--status-pending: #FAAD14;
--status-approved: #52C41A;
--status-rejected: #FF4D4F;
--status-cancelled: #9E9E9E;
--status-completed: #1890FF;
--status-noshow: #A8071A;

/* 信誉分 */
--credit-high: #52C41A;
--credit-medium: #FAAD14;
--credit-low: #FF4D4F;
