/* ==================== CSS变量定义 ==================== */
page {
  /* 主色调 - 集成蓝 */
  --primary-color: #1890FF;
  --primary-light: #40A9FF;
  --primary-dark: #096DD9;
  --primary-gradient: linear-gradient(135deg, #1890FF 0%, #096DD9 100%);

  /* 功能色 */
  --success-color: #52C41A;
  --warning-color: #FAAD14;
  --error-color: #FF4D4F;
  --info-color: #1890FF;
  --disabled-color: #999999;

  /* 中性色 */
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --text-placeholder: #CCCCCC;

  /* 背景色 */
  --bg-primary: #F5F5F5;
  --bg-white: #FFFFFF;
  --bg-gray: #F5F5F5;

  /* 边框色 */
  --border-color: #E8E8E8;
  --border-light: #F0F0F0;

  /* 圆角 */
  --border-radius-sm: 6rpx;
  --border-radius-md: 12rpx;
  --border-radius-lg: 16rpx;
  --border-radius-xl: 24rpx;
  --border-radius-round: 9999rpx;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  --spacing-xxl: 64rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  --shadow-primary: 0 4rpx 16rpx rgba(24, 144, 255, 0.25);
  --shadow-hover: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);

  /* 字体 */
  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 48rpx;

  /* 页面背景 */
  background-color: var(--bg-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  color: var(--text-primary);
  font-size: var(--font-size-md);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ==================== 深色模式 ==================== */
page.theme-dark-pro {
  --primary-color: #60A5FA;
  --primary-light: #93C5FD;
  --primary-dark: #3B82F6;
  --primary-gradient: linear-gradient(135deg, #60A5FA 0%, #3B82F6 100%);

  --success-color: #4ADE80;
  --warning-color: #FBBF24;
  --error-color: #F87171;
  --info-color: #60A5FA;
  --disabled-color: #475569;

  --text-primary: #F1F5F9;
  --text-secondary: #CBD5E1;
  --text-tertiary: #64748B;
  --text-placeholder: #475569;

  --bg-primary: #0F172A;
  --bg-white: #1E293B;
  --bg-gray: #1E293B;

  --border-color: rgba(148, 163, 184, 0.2);
  --border-light: rgba(148, 163, 184, 0.1);

  --shadow-sm: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
  --shadow-md: 0 4rpx 20rpx rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.5);
  --shadow-primary: 0 4rpx 16rpx rgba(96, 165, 250, 0.3);
  --shadow-hover: 0 8rpx 24rpx rgba(0, 0, 0, 0.5);

  background-color: var(--bg-primary);
}

/* ==================== 布局类 ==================== */
.flex {
  display: flex;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-nowrap {
  flex-wrap: nowrap;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-around {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.flex-start {
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.flex-end {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.flex-1 {
  flex: 1;
  min-width: 0;
}

.flex-shrink-0 {
  flex-shrink: 0;
}

