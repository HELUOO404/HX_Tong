.about-container {
  min-height: 100vh;
  padding: 24rpx 0;
}

.about-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: var(--shadow-sm);
}

.app-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.app-version {
  font-size: 28rpx;
}

.about-section {
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.info-value {
  font-size: 28rpx;
  text-align: right;
  max-width: 400rpx;
  word-break: break-all;
}

.about-footer {
  text-align: center;
  padding: 48rpx 32rpx;
}

.copyright {
  font-size: 24rpx;
}
