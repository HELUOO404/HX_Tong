<view class="login-container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <image class="logo" src="/assets/images/logo.png" mode="aspectFit"/>
    <text class="app-name">红芯通</text>
    <text class="app-slogan">深职大集成电路学院生活服务</text>
  </view>

  <!-- 登录区域 -->
  <view class="login-section">
    <view class="login-card">
      <text class="login-title">欢迎使用</text>
      <text class="login-desc">请授权微信登录，开启便捷服务</text>

      <!-- 登录按钮 -->
      <button 
        class="login-btn {{isLoading ? 'loading' : ''}}"
        bindtap="handleLogin"
        disabled="{{isLoading}}"
      >
        <image class="wechat-icon" src="/assets/images/icons/wechat.png" mode="aspectFit"/>
        <text>{{isLoading ? '登录中...' : '微信一键登录'}}</text>
      </button>

      <!-- 提示信息 -->
      <view class="tips">
        <text class="tip-text">登录即表示您同意</text>
        <text class="tip-link" bindtap="showUserAgreement">《用户协议》</text>
        <text class="tip-text">和</text>
        <text class="tip-link" bindtap="showPrivacyPolicy">《隐私政策》</text>
      </view>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-text">深圳职业技术大学 集成电路学院</text>
    <text class="footer-version">v2.1.0</text>
  </view>
</view>
