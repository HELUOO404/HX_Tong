.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  box-sizing: border-box;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  padding-bottom: 60rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background-color: var(--bg-white);
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  padding: 10rpx;
  box-sizing: border-box;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--bg-white);
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 登录区域 */
.login-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.login-card {
  background-color: var(--bg-white);
  border-radius: var(--border-radius-lg);
  padding: 64rpx 48rpx;
  box-shadow: var(--shadow-lg);
}

.login-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 16rpx;
}

.login-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-tertiary);
  text-align: center;
  margin-bottom: 64rpx;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #07C160 0%, #05a350 100%);
  color: var(--bg-white);
  font-size: 32rpx;
  font-weight: 500;
  padding: 28rpx 0;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
  margin-bottom: 48rpx;
}

.login-btn::after {
  border: none;
}

.login-btn.loading {
  opacity: 0.7;
}

.wechat-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

/* 提示信息 */
.tips {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
}

.tip-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.tip-link {
  font-size: 24rpx;
  color: var(--primary-color);
  margin: 0 4rpx;
}

/* 底部信息 */
.footer {
  padding: 48rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.footer-version {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}
