<view class="profile-container" style="background-color: {{theme.background}};">
  <!-- 头部卡片 -->
  <view class="header-card" style="background: linear-gradient(180deg, {{theme.primary}} 0%, {{theme.primaryDark}} 100%);">
    <view class="user-section">
      <block wx:if="{{isLogin}}">
        <image class="avatar avatar-preview" src="{{userInfo.avatarUrl || '/assets/images/logo.jpg'}}" mode="aspectFill" bindtap="onPreviewAvatar"/>
        <view class="user-info" bindtap="onEditProfile">
          <text class="user-name">{{userInfo.nickname || userInfo.realName || '用户'}}</text>
          <text class="user-class" wx:if="{{userInfo.remark}}">{{userInfo.remark}}</text>
          <view class="user-role" wx:if="{{hasPermissionTag}}">
            <text class="role-tag">{{adminRoleName}}</text>
          </view>
        </view>
        <view class="edit-profile-btn" bindtap="onEditProfile">
          <image class="edit-icon theme-icon" src="/assets/images/icons/edit.png" mode="aspectFit"/>
          <text class="edit-text">编辑</text>
        </view>
      </block>
      <block wx:else>
        <view class="not-login" bindtap="onLogin">
          <view class="avatar-placeholder">
            <image class="default-avatar theme-icon" src="/assets/images/icons/user.png" mode="aspectFit"/>
          </view>
          <view class="login-info">
            <text class="login-text">点击登录</text>
            <text class="login-desc">登录后享受完整服务</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions-section" style="background-color: {{theme.card}};" wx:if="{{isLogin}}">
    <view class="quick-actions">
      <view class="action-item" bindtap="onEditProfile">
        <view class="action-icon" style="background-color: {{theme.primary}}20;">
          <image src="/assets/images/icons/edit.png" mode="aspectFit"/>
        </view>
        <text class="action-name" style="color: {{theme.textPrimary}};">修改信息</text>
      </view>
      <view class="action-item" bindtap="onChangeTheme">
        <view class="action-icon" style="background-color: {{theme.primary}}15;">
          <image src="/assets/images/icons/theme.png" mode="aspectFit"/>
        </view>
        <text class="action-name" style="color: {{theme.textPrimary}};">更换主题</text>
      </view>
      <view class="action-item" bindtap="onSettings">
        <view class="action-icon" style="background-color: {{theme.primary}}10;">
          <image src="/assets/images/icons/settings.png" mode="aspectFit"/>
        </view>
        <text class="action-name" style="color: {{theme.textPrimary}};">设置</text>
      </view>
    </view>
  </view>

  <!-- 常用功能 -->
  <view class="section" style="background-color: {{theme.card}};" wx:if="{{isLogin}}">
    <view class="section-title" style="color: {{theme.textPrimary}};">常用功能</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="onMyBookings">
        <view class="menu-icon" style="background-color: {{theme.primary}}15;">
          <image src="/assets/images/icons/booking.png" mode="aspectFit"/>
        </view>
        <view class="menu-text">
          <text class="menu-name" style="color: {{theme.textPrimary}};">我的预约</text>
          <text class="menu-desc" style="color: {{theme.textSecondary}};">查看预约记录</text>
        </view>
        <image class="arrow-icon" src="/assets/images/icons/arrow-right.png" mode="aspectFit"/>
      </view>
      <view class="menu-item" bindtap="onCreditScore">
        <view class="menu-icon" style="background-color: {{theme.primary}}15;">
          <image src="/assets/images/icons/credit.png" mode="aspectFit"/>
        </view>
        <view class="menu-text">
          <text class="menu-name" style="color: {{theme.textPrimary}};">信誉分</text>
          <text class="menu-desc" style="color: {{theme.textSecondary}};">当前信誉分: {{userInfo.creditScore || 100}}</text>
        </view>
        <image class="arrow-icon" src="/assets/images/icons/arrow-right.png" mode="aspectFit"/>
      </view>
    </view>
  </view>

  <!-- 管理功能 -->
  <view class="section" style="background-color: {{theme.card}};" wx:if="{{hasPermissionTag}}">
    <view class="section-title" style="color: {{theme.textPrimary}};">管理功能</view>
    <view class="menu-list">
      <view class="menu-item admin-entry" bindtap="onEnterAdminBackend">
        <view class="menu-icon" style="background-color: {{theme.primary}}20;">
          <image src="/assets/images/icons/admin.png" mode="aspectFit"/>
        </view>
        <view class="menu-text">
          <text class="menu-name" style="color: {{theme.textPrimary}};">管理后台</text>
          <text class="menu-desc" style="color: {{theme.textSecondary}};">{{adminRoleName}}</text>
        </view>
        <image class="arrow-icon" src="/assets/images/icons/arrow-right.png" mode="aspectFit"/>
      </view>
    </view>
  </view>

  <!-- 其他 -->
  <view class="section" style="background-color: {{theme.card}};" wx:if="{{isLogin}}">
    <view class="section-title" style="color: {{theme.textPrimary}};">其他</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="onAbout">
        <view class="menu-icon" style="background-color: {{theme.success}}15;">
          <image src="/assets/images/icons/notice.png" mode="aspectFit"/>
        </view>
        <text class="menu-name" style="color: {{theme.textPrimary}};">关于</text>
        <image class="arrow-icon" src="/assets/images/icons/arrow-right.png" mode="aspectFit"/>
      </view>
      <view class="menu-item" bindtap="onLogout">
        <view class="menu-icon" style="background-color: {{theme.error}}15;">
          <image src="/assets/images/icons/close.png" mode="aspectFit"/>
        </view>
        <text class="menu-name" style="color: {{theme.error}};">退出登录</text>
        <image class="arrow-icon" src="/assets/images/icons/arrow-right.png" mode="aspectFit"/>
      </view>
    </view>
  </view>

  <view class="version-info" style="color: {{theme.textTertiary}};">{{appName}} v{{appVersion}}</view>
</view>
