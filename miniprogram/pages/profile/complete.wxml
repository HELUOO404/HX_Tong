<view class="complete-container">
  <view class="header-section">
    <text class="header-title">完善个人信息</text>
    <text class="header-desc">请填写真实信息，以便使用预约服务</text>
  </view>

  <view class="form-section">
    <view class="form-item avatar-item">
      <button
        class="avatar-btn"
        bindchooseavatar="onChooseAvatar"
        open-type="chooseAvatar"
      >
        <view class="avatar-wrapper">
          <image
            class="avatar-preview"
            src="{{avatarUrl || '/assets/images/logo.png'}}"
            mode="aspectFill"
          />
          <view class="avatar-edit-hint">点击更换</view>
        </view>
      </button>
    </view>

    <view class="form-item">
      <text class="form-label">真实姓名 <text class="required">*</text></text>
      <input 
        class="form-input" 
        type="text" 
        placeholder="请输入真实姓名"
        value="{{realName}}"
        bindinput="onRealNameInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">学院 <text class="required">*</text></text>
      <picker mode="selector" range="{{academies}}" bindchange="onSelectAcademy">
        <view class="form-picker {{academy ? 'selected' : ''}}">
          <text>{{academy || '请选择学院'}}</text>
          <image src="/assets/images/icons/arrow-down.png" style="width:28rpx;height:28rpx;"/>
        </view>
      </picker>
    </view>

    <view class="form-item" wx:if="{{needClassSelect}}">
      <text class="form-label">班级 <text class="required">*</text></text>
      <picker mode="selector" range="{{icClasses}}" bindchange="onSelectClass">
        <view class="form-picker {{className ? 'selected' : ''}}">
          <text>{{className || '请选择班级'}}</text>
          <image src="/assets/images/icons/arrow-down.png" style="width:28rpx;height:28rpx;"/>
        </view>
      </picker>
    </view>

    <view class="form-item" wx:if="{{showClassInput}}">
      <text class="form-label">班级 <text class="required">*</text></text>
      <input 
        class="form-input" 
        type="text" 
        placeholder="请输入班级名称"
        value="{{className}}"
        bindinput="onClassNameInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">学号 <text class="required">*</text></text>
      <input 
        class="form-input" 
        type="text" 
        placeholder="请输入学号"
        value="{{studentId}}"
        bindinput="onStudentIdInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">手机号 <text class="required">*</text></text>
      <input 
        class="form-input" 
        type="number" 
        maxlength="11"
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>
  </view>

  <view class="submit-section">
    <button 
      class="submit-btn {{isSubmitting ? 'loading' : ''}}"
      bindtap="onSubmit"
      disabled="{{isSubmitting}}"
    >
      {{isSubmitting ? '保存中...' : '完成'}}
    </button>
    <button class="refuse-btn" bindtap="onRefuse">拒绝填写</button>
  </view>
</view>
