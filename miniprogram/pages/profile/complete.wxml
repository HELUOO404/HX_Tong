<view class="complete-container">
  <view class="header-section">
    <text class="header-title">完善个人信息</text>
    <text class="header-desc">请填写昵称，以便使用预约服务</text>
  </view>

  <view class="form-section">
    <view class="form-item avatar-item">
      <text class="form-label">头像 <text class="optional">选填</text></text>
      <button
        class="avatar-btn"
        bindchooseavatar="onChooseAvatar"
        open-type="chooseAvatar"
      >
        <view class="avatar-wrapper">
          <image
            class="avatar-preview"
            src="{{avatarUrl || '/assets/images/logo.png'}}"
            mode="aspectFill"
          />
          <view class="avatar-edit-hint">点击更换</view>
        </view>
      </button>
    </view>

    <view class="form-item">
      <text class="form-label">昵称 <text class="required">*</text></text>
      <input
        class="form-input"
        type="text"
        maxlength="20"
        placeholder="请输入昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">备注 <text class="optional">选填</text></text>
      <textarea
        class="form-textarea"
        maxlength="200"
        placeholder="选填，如班级等"
        value="{{remark}}"
        bindinput="onRemarkInput"
        auto-height
        show-confirm-bar="{{false}}"
      />
    </view>
  </view>

  <view class="submit-section">
    <button
      class="submit-btn {{isSubmitting ? 'loading' : ''}}"
      bindtap="onSubmit"
      disabled="{{isSubmitting}}"
    >
      {{isSubmitting ? '保存中...' : '完成'}}
    </button>
    <button class="refuse-btn" bindtap="onRefuse">拒绝填写</button>
  </view>
</view>
