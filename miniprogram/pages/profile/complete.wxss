.complete-container {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

/* 顶部标题 */
.header-section {
  margin-bottom: 48rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.header-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 表单区域 */
.form-section {
  background-color: var(--bg-white);
  border-radius: var(--border-radius-lg);
  padding: 32rpx;
  margin-bottom: 48rpx;
  box-shadow: var(--shadow-sm);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.required {
  color: var(--error-color);
}

.form-input {
  width: 100%;
  height: 88rpx;
  background-color: var(--bg-primary);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-input::placeholder {
  color: var(--text-placeholder);
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  height: 88rpx;
  background-color: var(--bg-primary);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-placeholder);
  box-sizing: border-box;
}

.form-picker.selected {
  color: var(--text-primary);
}

/* 提交区域 */
.submit-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: var(--primary-gradient);
  color: var(--bg-white);
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-primary);
}

.submit-btn::after {
  border: none;
}

.submit-btn.loading {
  opacity: 0.7;
}

.avatar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: normal;
  width: 200rpx;
  height: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-btn::after {
  border: none;
}

.avatar-wrapper {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 4rpx solid var(--border-color);
}

.avatar-edit-hint {
  font-size: 24rpx;
  color: var(--primary-color);
  text-align: center;
  margin-top: 8rpx;
}

.nickname-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.nickname-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.nickname-input {
  font-size: 28rpx;
  color: var(--text-primary);
  text-align: center;
  border: none;
  background: transparent;
  padding: 8rpx;
}

.nickname-input::placeholder {
  color: var(--primary-color);
}

.avatar-hint {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.skip-link {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.refuse-btn {
  width: 100%;
  height: 96rpx;
  background-color: var(--bg-white);
  color: var(--text-secondary);
  font-size: 32rpx;
  border-radius: 48rpx;
  border: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.refuse-btn::after {
  border: none;
}
