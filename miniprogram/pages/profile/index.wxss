.profile-container {
  min-height: 100vh;
  padding-bottom: 48rpx;
}

/* 头部卡片 */
.header-card {
  padding: 48rpx 32rpx 64rpx;
  border-radius: 0 0 48rpx 48rpx;
}

.user-section {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background-color: var(--bg-white);
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background-color: var(--bg-white);
}

.user-info {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.user-class {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.user-role {
  margin-top: 4rpx;
}

.role-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #FFFFFF;
}

.not-login {
  display: flex;
  align-items: center;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.default-avatar {
  width: 60rpx;
  height: 60rpx;
  filter: brightness(0) invert(1);
  opacity: 0.8;
}

.login-info {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.login-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.login-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.edit-profile-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.2);
  margin-left: auto;
}

.edit-profile-btn:active {
  opacity: 0.7;
}

.edit-icon {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
  margin-bottom: 4rpx;
}

.edit-text {
  font-size: 22rpx;
  color: #FFFFFF;
}

/* 快捷操作 - 修复重叠：去掉负margin，使用正margin */
.quick-actions-section {
  margin: 24rpx 32rpx 0;
  border-radius: var(--border-radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.quick-actions {
  display: flex;
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
}

.action-item:active {
  opacity: 0.7;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-icon image {
  width: 56rpx;
  height: 56rpx;
}

.action-name {
  font-size: 26rpx;
}

/* 功能区块 */
.section {
  margin: 24rpx 32rpx 0;
  border-radius: var(--border-radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  background-color: var(--bg-white);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  opacity: 0.7;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-icon image {
  width: 48rpx;
  height: 48rpx;
}

.menu-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.menu-name {
  font-size: 30rpx;
  margin-bottom: 4rpx;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.version-info {
  text-align: center;
  padding: 48rpx 0 24rpx;
  font-size: 24rpx;
}
