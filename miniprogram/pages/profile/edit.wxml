<view class="edit-container" style="background-color: {{theme.background}};">
  <view class="header-section">
    <text class="header-title">编辑个人信息</text>
    <text class="header-desc">头像、备注选填，昵称必填</text>
  </view>

  <view class="form-section" style="background-color: {{theme.card}};">
    <view class="form-item avatar-item">
      <text class="form-label" style="color: {{theme.textSecondary}};">头像 <text class="optional-tag">选填</text></text>
      <view class="avatar-wrapper" bindtap="onChangeAvatarTap">
        <image
          class="avatar-preview"
          src="{{avatarUrl || '/assets/images/logo.jpg'}}"
          mode="aspectFill"
        />
        <view class="avatar-edit-mask">
          <image class="edit-icon" src="/assets/images/icons/edit.png" mode="aspectFit"/>
          <text class="edit-text">更换头像</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label" style="color: {{theme.textSecondary}};">昵称 <text class="required-tag">*</text></text>
      <input
        class="form-input"
        type="text"
        maxlength="20"
        placeholder="请输入昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        style="color: {{theme.textPrimary}}; background: {{theme.background}};"
      />
    </view>

    <view class="form-item">
      <text class="form-label" style="color: {{theme.textSecondary}};">备注 <text class="optional-tag">选填</text></text>
      <textarea
        class="form-textarea"
        maxlength="200"
        placeholder="选填，如班级等"
        value="{{remark}}"
        bindinput="onRemarkInput"
        auto-height
        show-confirm-bar="{{false}}"
        style="color: {{theme.textPrimary}}; background: {{theme.background}};"
      />
    </view>
  </view>

  <view class="button-section">
    <button
      class="save-btn {{isSubmitting ? 'loading' : ''}}"
      bindtap="onSave"
      disabled="{{isSubmitting}}"
      style="background-color: {{theme.primary}};"
    >
      {{isSubmitting ? '保存中...' : '保存'}}
    </button>
    <button
      class="cancel-btn"
      bindtap="onCancel"
      style="color: {{theme.textSecondary}}; border-color: {{theme.border}};"
    >
      取消
    </button>
  </view>
</view>
