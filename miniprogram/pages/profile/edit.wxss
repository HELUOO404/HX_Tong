.edit-container {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.header-section {
  margin-bottom: 48rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.header-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.form-section {
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 48rpx;
  box-shadow: var(--shadow-sm);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.avatar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 16rpx;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 4rpx solid var(--border-color);
}

.avatar-edit-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.avatar-wrapper:active .avatar-edit-mask {
  opacity: 1;
}

.edit-icon {
  width: 40rpx;
  height: 40rpx;
  filter: brightness(0) invert(1);
  margin-bottom: 8rpx;
}

.edit-text {
  font-size: 22rpx;
  color: #FFFFFF;
}

.avatar-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background-color: var(--bg-primary);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-input::placeholder {
  color: var(--text-placeholder);
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 12rpx;
}

.button-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-primary);
}

.save-btn::after {
  border: none;
}

.save-btn.loading {
  opacity: 0.7;
}

.cancel-btn {
  width: 100%;
  height: 96rpx;
  background-color: transparent;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: 2rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn::after {
  border: none;
}