.credit-container {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding: 24rpx;
  padding-bottom: 48rpx;
}

/* 信誉分卡片 */
.credit-card {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: var(--border-radius-lg);
  padding: 64rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-primary);
}

.credit-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 120rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.credit-score {
  font-size: 72rpx;
  font-weight: bold;
  color: var(--bg-white);
  line-height: 1;
}

.credit-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.credit-level {
  background-color: rgba(255, 255, 255, 0.2);
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
}

.credit-level text {
  font-size: 28rpx;
  color: var(--bg-white);
  font-weight: 500;
}

/* 规则说明 */
.rules-section,
.records-section {
  background-color: var(--bg-white);
  border-radius: var(--border-radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rule-item {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 变动记录 */
.loading-container {
  display: flex;
  justify-content: center;
  padding: 48rpx 0;
}

.records-list {
  display: flex;
  flex-direction: column;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.record-reason {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.record-score {
  font-size: 32rpx;
  font-weight: bold;
}

.record-score.plus {
  color: var(--success-color);
}

.record-score.minus {
  color: var(--error-color);
}

.empty-container {
  display: flex;
  justify-content: center;
  padding: 48rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}
