/* 主题设置页面样式 */

.theme-settings-container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 页面标题 */
.header {
  padding: 60rpx 40rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
}

/* 当前主题预览 */
.current-theme-preview {
  margin: 30rpx 40rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  border: 2rpx solid;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.preview-label {
  font-size: 28rpx;
}

.preview-content {
  display: flex;
  align-items: center;
}

.theme-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.theme-name {
  font-size: 32rpx;
  font-weight: 500;
}

/* 主题列表 */
.theme-list {
  padding: 0 40rpx;
}

.theme-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  position: relative;
  transition: all 0.3s ease;
}

.theme-item:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.theme-item.active {
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

/* 主题预览图 */
.theme-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  margin-right: 30rpx;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.selected-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.check-icon {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: bold;
}

/* 主题信息 */
.theme-info {
  flex: 1;
}

.theme-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.theme-desc {
  display: block;
  font-size: 26rpx;
}

/* 选中指示器 */
.active-indicator {
  width: 8rpx;
  height: 60rpx;
  border-radius: 4rpx;
  margin-left: 20rpx;
}

/* 提示信息 */
.tips {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
  padding: 0 40rpx;
  font-size: 26rpx;
}

.tip-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}
