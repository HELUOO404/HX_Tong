.admin-index-container {
  min-height: 100%;
  background-color: var(--bg-primary);
  padding-bottom: 48rpx;
}

/* 管理员信息 */
.admin-header {
  background: var(--primary-gradient);
  padding: 48rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.admin-info {
  display: flex;
  flex-direction: column;
}

.admin-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  word-break: break-all;
  overflow-wrap: break-word;
}

.admin-role {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.logout-btn {
  font-size: 28rpx;
  color: #FFFFFF;
  padding: 16rpx 32rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
}

/* 数据统计 */
.stats-section {
  padding: 24rpx;
  margin-top: -32rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.stat-card {
  background-color: var(--bg-white);
  border-radius: var(--border-radius-lg);
  padding: 32rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.2s ease;
}

.stat-card:active {
  box-shadow: var(--shadow-md);
}

.stat-card.highlight {
  background: linear-gradient(135deg, var(--warning-color) 0%, #F97316 100%);
}

.stat-card.highlight .stat-value,
.stat-card.highlight .stat-label {
  color: #FFFFFF;
}

.stat-card.highlight.stat-card-clickable:active {
  transform: scale(0.98);
  opacity: 0.92;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 功能菜单 */
.menu-section {
  margin: 0 24rpx 24rpx;
  background-color: var(--bg-white);
  border-radius: var(--border-radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: var(--bg-primary);
  border-radius: 12rpx;
  position: relative;
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.menu-name {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  min-width: 36rpx;
  height: 36rpx;
  background-color: var(--error-color);
  color: var(--bg-white);
  font-size: 22rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  z-index: 1;
}

/* 开发工具菜单项样式 */
.menu-item-dev {
  opacity: 0.6;
  border: 1rpx dashed #999999;
}

.menu-item-dev .menu-icon {
  background-color: #99999920 !important;
}

.menu-item-dev .menu-name {
  color: #999999;
}

/* 最近预约 */
.recent-section {
  margin: 0 24rpx;
  background-color: var(--bg-white);
  border-radius: var(--border-radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recent-item {
  padding: 24rpx;
  border-radius: 16rpx;
  background-color: var(--bg-gray, #f7f8fa);
  border: 1rpx solid var(--border-light, #eee);
}

.recent-item-clickable {
  transition: background-color 0.15s ease, border-color 0.15s ease;
}

.recent-item-hover {
  background-color: rgba(24, 144, 255, 0.06);
  border-color: rgba(24, 144, 255, 0.25);
}

.recent-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  min-width: 0;
}

.recent-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.recent-head-main {
  flex: 1;
  min-width: 0;
}

.recent-title {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  font-size: 30rpx;
  line-height: 1.45;
  margin-bottom: 12rpx;
}

.recent-room,
.recent-title-colon,
.recent-purpose {
  font-weight: 600;
  color: var(--text-primary);
}

.recent-room {
  flex-shrink: 0;
}

.recent-title-colon {
  flex-shrink: 0;
  margin-right: 4rpx;
}

.recent-purpose {
  flex: 1;
  min-width: 0;
  word-break: break-all;
}

.recent-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.recent-tag {
  font-size: 22rpx;
  line-height: 1.2;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background-color: rgba(24, 144, 255, 0.1);
  color: var(--primary-color, #1890ff);
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-tag-muted {
  background-color: rgba(0, 0, 0, 0.04);
  color: var(--text-secondary);
}

.recent-status {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.recent-detail {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.recent-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background-color: #fff;
  border: 1rpx solid var(--border-light, #eee);
}

.recent-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.recent-meta-line {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.meta-label {
  flex-shrink: 0;
  width: 56rpx;
  color: var(--text-tertiary, #999);
}

.meta-value {
  flex: 1;
  min-width: 0;
  color: var(--text-secondary);
  word-break: break-all;
}

.meta-mono {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  letter-spacing: 0.5rpx;
}

.status-pending {
  background-color: rgba(250, 173, 20, 0.12);
  color: var(--warning-color);
}

.status-approved {
  background-color: rgba(82, 196, 26, 0.12);
  color: var(--success-color);
}

.status-rejected {
  background-color: rgba(255, 77, 79, 0.12);
  color: var(--error-color, #ff4d4f);
}

.status-cancelled,
.status-expired {
  background-color: rgba(0, 0, 0, 0.06);
  color: var(--text-tertiary, #999);
}

.status-completed {
  background-color: rgba(24, 144, 255, 0.1);
  color: var(--primary-color, #1890ff);
}

.empty-tip {
  text-align: center;
  padding: 48rpx 0;
  color: var(--text-tertiary);
  font-size: 28rpx;
}
