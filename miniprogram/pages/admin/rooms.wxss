/* pages/admin/rooms.wxss */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background-color: var(--bg-primary);
}

/* 头部栏 */
.header-bar {
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.add-btn {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 32rpx;
  border-radius: var(--border-radius-md);
  color: var(--bg-white);
  font-size: 28rpx;
  background: var(--primary-gradient);
  box-shadow: var(--shadow-primary);
}

.add-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

/* 会议室列表 */
.room-list {
  padding: 0 30rpx;
}

.room-card {
  border-radius: var(--border-radius-lg);
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid transparent;
  background-color: var(--bg-white);
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.2s ease;
}

.room-card:active {
  box-shadow: var(--shadow-md);
}

.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.room-title {
  display: flex;
  align-items: center;
}

.room-name {
  font-size: 32rpx;
  font-weight: 500;
  margin-right: 16rpx;
  color: var(--text-primary);
  word-break: break-all;
  overflow-wrap: break-word;
  flex: 1;
  min-width: 0;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--border-radius-sm);
  background: var(--bg-gray);
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.status-tag.available {
  background: rgba(82, 196, 26, 0.12);
  color: var(--success-color);
}

.status-tag.disabled {
  background: var(--bg-gray);
  color: var(--text-tertiary);
}

.room-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 64rpx;
  min-height: 88rpx;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--primary-color);
}

/* 详细信息 */
.room-detail {
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-light);
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  width: 140rpx;
  flex-shrink: 0;
  color: var(--text-secondary);
}

.info-row text:last-child {
  font-size: 26rpx;
  flex: 1;
  min-width: 0;
  word-break: break-all;
  overflow-wrap: break-word;
  color: var(--text-primary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-state text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.empty-tip {
  font-size: 24rpx;
  margin-top: 16rpx;
  color: var(--text-tertiary);
}

/* 加载中 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

