page {
  height: 100%;
}

.admin-login-container {
  min-height: 100%;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  padding: 80rpx 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 标题 */
.header-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单 */
.form-section {
  background-color: var(--bg-white);
  border-radius: var(--border-radius-lg);
  padding: 64rpx 48rpx;
  box-shadow: var(--shadow-lg);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  background-color: var(--bg-primary);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-input::placeholder {
  color: var(--text-placeholder);
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: var(--primary-gradient);
  color: var(--bg-white);
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  margin-top: 24rpx;
  box-shadow: var(--shadow-primary);
}

.login-btn::after {
  border: none;
}

.login-btn.loading {
  opacity: 0.7;
}

/* 底部 */
.footer-section {
  margin-top: 48rpx;
  text-align: center;
}

.back-link {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}
