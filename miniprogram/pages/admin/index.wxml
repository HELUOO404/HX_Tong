<view class="admin-index-container">
  <!-- 管理员信息 -->
  <view class="admin-header">
    <view class="admin-info">
      <text class="admin-name">{{adminInfo.name || adminInfo.username || '管理员'}}</text>
      <text class="admin-role">{{adminRoleName}}</text>
    </view>
    <view class="logout-btn" bindtap="onLogout">退出</view>
  </view>

  <!-- 数据统计卡片 -->
  <view class="stats-section">
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-value">{{stats.totalUsers}}</text>
        <text class="stat-label">总用户数</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.totalBookings}}</text>
        <text class="stat-label">总预约数</text>
      </view>
      <view
        class="stat-card highlight {{canApproveBookings ? 'stat-card-clickable' : ''}}"
        bindtap="onPendingApprovalsTap"
      >
        <text class="stat-value">{{stats.pendingApprovals}}</text>
        <text class="stat-label">待审批</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.todayBookings}}</text>
        <text class="stat-label">今日预约</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <text class="section-title">功能菜单</text>
    <view class="menu-grid">
      <view 
        class="menu-item {{item.isDev ? 'menu-item-dev' : ''}}"
        wx:for="{{menuList}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onMenuTap"
      >
        <view class="menu-icon" style="background-color: {{item.color}}20;">
          <image src="{{item.icon}}" mode="aspectFit" style="width: 40rpx; height: 40rpx;"/>
        </view>
        <text class="menu-name">{{item.name}}</text>
        <view class="menu-badge" wx:if="{{item.count > 0}}">{{item.count}}</view>
      </view>
    </view>
  </view>

  <!-- 最近预约 -->
  <view class="recent-section">
    <text class="section-title">最近预约</text>
    <view class="recent-list" wx:if="{{recentBookings.length > 0}}">
      <view
        class="recent-item recent-item-clickable"
        wx:for="{{recentBookings}}"
        wx:key="_id"
        hover-class="recent-item-hover"
        data-id="{{item._id}}"
        bindtap="onRecentBookingTap"
      >
        <view class="recent-body">
          <view class="recent-head">
            <view class="recent-head-main">
              <view class="recent-title">
                <text class="recent-room">{{item.roomName}}</text>
                <text class="recent-title-colon">：</text>
                <text class="recent-purpose">{{item.purpose || '无会议主题'}}</text>
              </view>
              <view class="recent-tags" wx:if="{{item.nickname || item.remark}}">
                <text class="recent-tag" wx:if="{{item.nickname}}">{{item.nickname}}</text>
                <text class="recent-tag recent-tag-muted" wx:if="{{item.remark}}">{{item.remark}}</text>
              </view>
            </view>
            <view class="recent-status status-{{item.status}}">{{item.statusText}}</view>
          </view>

          <view class="recent-detail">
            <image
              class="recent-avatar"
              src="{{item.avatarUrl || defaultAvatar}}"
              mode="aspectFill"
            />
            <view class="recent-meta">
              <view class="recent-meta-line" wx:if="{{item.attendees !== ''}}">
                <text class="meta-label">人数</text>
                <text class="meta-value">{{item.attendees}} 人</text>
              </view>
              <view class="recent-meta-line" wx:if="{{item.contactPhone}}">
                <text class="meta-label">联系</text>
                <text class="meta-value meta-mono">{{item.contactPhone}}</text>
              </view>
              <view class="recent-meta-line" wx:if="{{item.timeText}}">
                <text class="meta-label">时段</text>
                <text class="meta-value">{{item.timeText}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:else>
      <text>暂无预约记录</text>
    </view>
  </view>
</view>
