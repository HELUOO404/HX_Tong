/* pages/admin/users.wxss */
.page {
  min-height: 100%;
  padding-bottom: 40rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.search-btn {
  margin-left: 20rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.role-picker {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 500;
}

.role-picker .arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
}

.filter-scroll {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-tag {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  flex-shrink: 0;
  background: rgba(0, 0, 0, 0.04);
}

.filter-tag.active {
  background: #1890FF;
  color: #fff;
  font-weight: bold;
}

/* 统计栏 */
.stats-bar {
  padding: 20rpx 30rpx;
  font-size: 26rpx;
  margin-bottom: 20rpx;
}

/* 用户列表 */
.user-list {
  padding: 0 30rpx;
}

.user-card {
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid transparent;
  display: flex;
  flex-direction: column;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #f0f0f0;
}

.user-detail {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.user-name {
  font-size: 32rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-phone {
  font-size: 26rpx;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.meta-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

.department {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

/* 用户统计 */
.user-stats {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  width: 100%;
}

.role-badge {
  flex-shrink: 0;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  max-width: 50%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.role-badge.user {
  background: #e6f7ff;
  color: #1890ff;
}

.role-badge.admin {
  background: #fff7e6;
  color: #fa8c16;
}

.role-badge.superAdmin {
  background: #f6ffed;
  color: #52c41a;
}

.credit-score {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
}

.dialog-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  z-index: 1001;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.dialog-content .modal-header {
  flex-shrink: 0;
  padding: 30rpx 30rpx 20rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.dialog-content .modal-body {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 24rpx 30rpx;
  box-sizing: border-box;
}

/* 用户操作 */
.user-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
  width: 100%;
  margin-top: 16rpx;
}

.action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-width: 0;
  min-height: 88rpx;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  text-align: center;
}

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-state text {
  font-size: 28rpx;
}

/* 加载中 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.tag-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 1001;
}

.tag-modal.show {
  transform: translateY(0);
}

.modal-content {
  max-height: 1200rpx;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 36rpx;
}

.modal-scroll {
  max-height: 60vh;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  color: #333;
}

.form-input {
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  border: 2rpx solid #e8e8e8;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
}

.form-input:focus {
  border-color: #1890ff;
}

.dialog-content .modal-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1;
  margin: 0;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.btn-cancel {
  background: #fff;
  color: #595959;
  border: 2rpx solid #d9d9d9;
}

.btn-confirm {
  color: #fff;
  background-color: #1890ff;
  border: none;
}

.btn-confirm.danger {
  background-color: #f44336;
}

.user-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 0 4rpx;
}

.user-tag {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  background: rgba(24, 144, 255, 0.1);
  color: #1890FF;
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.btn-tag-edit {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 64rpx;
  min-height: 88rpx;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  background: rgba(24, 144, 255, 0.1);
  color: #1890FF;
}

.tag-option {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.tag-option:last-child {
  border-bottom: none;
}

.tag-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #ccc;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #fff;
}

.tag-checkbox.checked {
  background: #1890FF;
  border-color: #1890FF;
  color: #fff;
}

.tag-option-name {
  font-size: 28rpx;
  flex: 1;
}

.tag-option-desc {
  font-size: 24rpx;
  margin-left: 16rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-row .search-input-wrap {
  flex: 1;
  margin-bottom: 0;
}

.filter-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
  white-space: nowrap;
}

.filter-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.filter-overlay.show {
  opacity: 1;
  visibility: visible;
}

.filter-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  flex-shrink: 0;
}

.filter-title {
  font-size: 32rpx;
  font-weight: bold;
}

.filter-reset {
  font-size: 26rpx;
  color: #1677ff;
}

.filter-body {
  flex: 1;
  padding: 20rpx 30rpx;
  overflow-y: auto;
}

.filter-group {
  margin-bottom: 30rpx;
}

.filter-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-tag {
  padding: 12rpx 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
}

.filter-tag.active {
  border-color: #1677ff;
  color: #1677ff;
  background: #e6f4ff;
}

.filter-range {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.range-input {
  flex: 1;
  padding: 12rpx 16rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 26rpx;
  text-align: center;
}

.range-sep {
  font-size: 26rpx;
  color: #999;
}

.filter-footer {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #eee;
  flex-shrink: 0;
}

.btn-filter-confirm {
  width: 100%;
  padding: 20rpx;
  background: #1677ff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
  border: none;
  line-height: 1;
}

.btn-filter-confirm::after {
  border: none;
}

.credit-adjust-btn {
  margin-left: 12rpx;
  padding: 8rpx 12rpx;
  font-size: 24rpx;
  text-decoration: underline;
  flex-shrink: 0;
}
