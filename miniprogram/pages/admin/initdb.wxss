page {
  --bg-primary: #1890FF;
  --bg-primary-dark: #096DD9;
  --bg-secondary: #8C8C8C;
  --bg-secondary-dark: #595959;
  --bg-warning: #FA8C16;
  --bg-warning-dark: #D46B08;
  --bg-danger: #FF4D4F;
  --bg-danger-dark: #CF1322;
  --bg-page: #F0F2F5;
  --bg-card: #FFFFFF;
  --text-primary: #262626;
  --text-secondary: #595959;
  --text-tertiary: #8C8C8C;
  --border-color: #E8E8E8;
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --radius-lg: 16rpx;
  --radius-md: 12rpx;
  background-color: var(--bg-page);
}

.container {
  padding: 32rpx 24rpx 48rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.console-header {
  text-align: center;
  padding: 48rpx 0 40rpx;
}

.console-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.console-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-tertiary);
  letter-spacing: 1rpx;
}

.section {
  background-color: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 20rpx;
  border-bottom: 1rpx solid var(--border-color);
  background: linear-gradient(135deg, #FAFBFC 0%, #FFFFFF 100%);
}

.section-icon {
  font-size: 40rpx;
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  background-color: #F0F5FF;
  border-radius: 14rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.section-title-group {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.4;
  margin-top: 4rpx;
}

.section-body {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: var(--radius-md);
  border: none;
  padding: 0;
  margin: 0;
  transition: all 0.2s ease;
}

.btn::after {
  border: none;
}

.btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-primary {
  background-color: var(--bg-primary);
  color: #FFFFFF;
}

.btn-primary:active {
  background-color: var(--bg-primary-dark);
}

.btn-secondary {
  background-color: #F5F5F5;
  color: var(--text-secondary);
  border: 2rpx solid var(--border-color);
}

.btn-secondary:active {
  background-color: #E8E8E8;
}

.btn-warning {
  background-color: var(--bg-warning);
  color: #FFFFFF;
}

.btn-warning:active {
  background-color: var(--bg-warning-dark);
}

.btn-danger {
  background-color: var(--bg-danger);
  color: #FFFFFF;
}

.btn-danger:active {
  background-color: var(--bg-danger-dark);
}

.btn[disabled] {
  opacity: 0.5;
}

.result-section {
  background-color: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  margin-top: 32rpx;
  overflow: hidden;
}

.result-header {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.result-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.result-scroll {
  max-height: 600rpx;
  padding: 24rpx 28rpx;
}

.result-content {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  word-break: break-all;
  white-space: pre-wrap;
  font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
}
