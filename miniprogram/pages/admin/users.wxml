<view class="page" style="background: {{theme.background}};">
  <view class="search-bar" style="background: {{theme.card}};">
    <view class="search-row">
      <view class="search-input-wrap">
        <input
          class="search-input"
          placeholder="搜索用户姓名/手机号/学号"
          placeholder-style="color: {{theme.textTertiary}};"
          value="{{keyword}}"
          bindinput="onSearch"
          style="color: {{theme.textPrimary}};"
        />
      </view>
      <view class="filter-btn" bindtap="onShowFilter">
        <text>筛选</text>
      </view>
    </view>
  </view>

  <view class="filter-scroll" style="background: {{theme.card}};">
    <view
      wx:for="{{filterTabs}}"
      wx:key="id"
      class="filter-tag {{tagFilter === item.id ? 'active' : ''}}"
      data-filter="{{item.id}}"
      bindtap="onTagFilter"
    >{{item.name}}</view>
  </view>

  <view class="stats-bar" style="background: {{theme.card}}; color: {{theme.textSecondary}};">
    共 {{total}} 位用户
  </view>

  <view class="user-list">
    <block wx:if="{{users.length > 0}}">
      <view
        wx:for="{{users}}"
        wx:for-index="userIndex"
        wx:key="_id"
        class="user-card"
        style="background: {{theme.card}}; border-color: {{theme.border}};"
      >
        <view class="user-info">
          <image class="avatar" src="{{item.avatarUrl || '/assets/images/logo.png'}}" mode="aspectFill"/>
          <view class="user-detail">
            <text class="user-name" style="color: {{theme.textPrimary}};">{{item.nickname || item.realName || '未设置昵称'}}</text>
            <text class="user-phone" style="color: {{theme.textSecondary}};">{{item.remark || '未填写备注'}}</text>
            <view class="user-meta">
              <text class="meta-tag" style="color: {{theme.textTertiary}}; background: {{theme.background}};" wx:if="{{item.phone}}">手机: {{item.phone}}</text>
            </view>
          </view>
        </view>

        <view class="user-tags-row" wx:if="{{item.permissionTags && item.permissionTags.length > 0}}">
          <view wx:for="{{item.permissionTags}}" wx:key="tagId" wx:for-item="tag" class="user-tag">{{tag.tagName || tag.name}}</view>
        </view>

        <view class="user-stats">
          <view class="role-badge {{item.role}}">
            <text wx:if="{{item.permissionTags && item.permissionTags.length > 0}}">{{item.permissionTags[0].tagName || '管理员'}}</text>
            <text wx:else>普通用户</text>
          </view>
          <view class="credit-score" style="color: {{theme.primary}};">
            信誉分: {{item.creditScore}}
            <view
              wx:if="{{canEditUser}}"
              class="credit-adjust-btn"
              catchtap="onShowCreditModal"
              data-idx="{{userIndex}}"
              style="color: {{theme.primary}};"
            >调整</view>
          </view>
        </view>

        <view class="user-actions">
          <view
            wx:if="{{canEditUser}}"
            class="action-btn edit"
            catchtap="onShowEditModal"
            data-idx="{{userIndex}}"
            style="color: {{theme.primary}};"
          >编辑</view>
          <view
            wx:if="{{canResetAvatar}}"
            class="action-btn danger"
            catchtap="onShowResetAvatarModal"
            data-idx="{{userIndex}}"
            style="color: #FF9800;"
          >重置头像</view>
          <view
            wx:if="{{canDeleteUser}}"
            class="action-btn danger"
            catchtap="onShowDeleteModal"
            data-idx="{{userIndex}}"
            style="color: #F44336;"
          >删除</view>
        </view>
      </view>

      <view wx:if="{{page < totalPages}}" class="load-more" bindtap="loadMore" style="color: {{theme.textSecondary}};">
        点击加载更多
      </view>
      <view wx:else class="no-more" style="color: {{theme.textTertiary}};">
        没有更多了
      </view>
    </block>

    <view wx:elif="{{!isLoading}}" class="empty-state">
      <image class="empty-icon" src="/assets/images/empty-room.png" mode="aspectFit"/>
      <text style="color: {{theme.textSecondary}};">暂无用户数据</text>
    </view>
  </view>

  <view wx:if="{{isLoading && users.length === 0}}" class="loading-state">
    <view class="loading-spinner" style="border-color: {{theme.primary}}; border-top-color: transparent;"></view>
    <text style="color: {{theme.textSecondary}};">加载中...</text>
  </view>

  <view wx:if="{{isShowDeleteModal}}" class="modal-mask show" catchtap="onCloseDeleteModal">
    <view class="dialog-content" style="background: {{theme.card}};" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title" style="color: {{theme.textPrimary}};">删除用户</text>
        <text class="modal-close" bindtap="onCloseDeleteModal" style="color: {{theme.textTertiary}};">×</text>
      </view>
      <view class="modal-body">
        <text style="color: {{theme.textSecondary}}; text-align: center; display: block;">确定要删除该用户吗？</text>
        <text style="color: {{theme.textTertiary}}; text-align: center; display: block; margin-top: 20rpx; font-size: 24rpx;">此操作不可恢复</text>
      </view>
      <view class="modal-footer">
        <view class="btn-cancel" bindtap="onCloseDeleteModal" style="border-color: {{theme.border}}; color: {{theme.textSecondary}};">
          取消
        </view>
        <view class="btn-confirm danger" bindtap="onConfirmDelete" style="background: #F44336;">
          确认删除
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{isShowResetAvatarModal}}" class="modal-mask show" catchtap="onCloseResetAvatarModal">
    <view class="dialog-content" style="background: {{theme.card}};" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title" style="color: {{theme.textPrimary}};">重置头像</text>
        <text class="modal-close" bindtap="onCloseResetAvatarModal" style="color: {{theme.textTertiary}};">×</text>
      </view>
      <view class="modal-body">
        <text style="color: {{theme.textSecondary}}; text-align: center; display: block;">确定要重置该用户的头像吗？</text>
        <text style="color: {{theme.textTertiary}}; text-align: center; display: block; margin-top: 20rpx; font-size: 24rpx;">头像将恢复为小程序Logo</text>
      </view>
      <view class="modal-footer">
        <view class="btn-cancel" bindtap="onCloseResetAvatarModal" style="border-color: {{theme.border}}; color: {{theme.textSecondary}};">
          取消
        </view>
        <view class="btn-confirm" bindtap="onConfirmResetAvatar">
          确认重置
        </view>
      </view>
    </view>
  </view>

  <view class="modal-mask {{isShowTagModal ? 'show' : ''}}" bindtap="onCloseTagModal"></view>
  <view class="tag-modal {{isShowTagModal ? 'show' : ''}}">
    <view class="modal-content" style="background: {{theme.card}};">
      <view class="modal-header">
        <text class="modal-title" style="color: {{theme.textPrimary}};">编辑权限标签</text>
        <view class="modal-close" bindtap="onCloseTagModal">
          <text style="color: {{theme.textTertiary}};">×</text>
        </view>
      </view>
      <scroll-view scroll-y class="modal-scroll">
        <view wx:for="{{availableTags}}" wx:key="tagId" class="tag-option" bindtap="onToggleTagSelection" data-tagid="{{item.tagId}}">
          <view class="tag-checkbox {{item.selected ? 'checked' : ''}}">
            <text wx:if="{{item.selected}}">✓</text>
          </view>
          <text class="tag-option-name" style="color: {{theme.textPrimary}};">{{item.name}}</text>
          <text class="tag-option-desc" style="color: {{theme.textTertiary}};" wx:if="{{item.description}}">{{item.description}}</text>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <button class="btn-cancel" style="border-color: {{theme.border}}; color: {{theme.textSecondary}};" bindtap="onCloseTagModal">取消</button>
        <button class="btn-confirm" style="background: {{theme.primary}};" bindtap="onConfirmTagEdit">确认</button>
      </view>
    </view>
  </view>

  <view class="filter-overlay {{showFilter ? 'show' : ''}}" catchtouchend="onHideFilter">
    <view class="filter-sheet" catchtouchend="preventClose">
      <view class="filter-header">
        <text class="filter-title">筛选条件</text>
        <text class="filter-reset" bindtap="onResetFilter">重置</text>
      </view>

      <scroll-view class="filter-body" scroll-y>
        <view class="filter-group">
          <text class="filter-label">学院</text>
          <view class="filter-tags">
            <view class="filter-tag {{filterAcademy === item ? 'active' : ''}}"
                  wx:for="{{academyOptions}}" wx:key="*this"
                  data-value="{{item}}" bindtap="onSelectAcademy">
              {{item}}
            </view>
          </view>
        </view>

        <view class="filter-group">
          <text class="filter-label">班级</text>
          <view class="filter-tags">
            <view class="filter-tag {{filterClassName === item ? 'active' : ''}}"
                  wx:for="{{classOptions}}" wx:key="*this"
                  data-value="{{item}}" bindtap="onSelectClass">
              {{item}}
            </view>
          </view>
        </view>

        <view class="filter-group">
          <text class="filter-label">信誉分范围</text>
          <view class="filter-range">
            <input class="range-input" placeholder="最低分" value="{{filterMinCredit}}" bindinput="onMinCreditInput" type="number"/>
            <text class="range-sep">-</text>
            <input class="range-input" placeholder="最高分" value="{{filterMaxCredit}}" bindinput="onMaxCreditInput" type="number"/>
          </view>
        </view>

        <view class="filter-group">
          <text class="filter-label">资料完善</text>
          <view class="filter-tags">
            <view class="filter-tag {{filterProfile === 'all' ? 'active' : ''}}" data-value="all" bindtap="onSelectProfile">全部</view>
            <view class="filter-tag {{filterProfile === true ? 'active' : ''}}" data-value="{{true}}" bindtap="onSelectProfile">已完善</view>
            <view class="filter-tag {{filterProfile === false ? 'active' : ''}}" data-value="{{false}}" bindtap="onSelectProfile">未完善</view>
          </view>
        </view>
      </scroll-view>

      <view class="filter-footer">
        <button class="btn-filter-confirm" bindtap="onApplyFilter">确认筛选</button>
      </view>
    </view>
  </view>

  <view wx:if="{{creditModalVisible}}" class="modal-mask show" catchtap="onCloseCreditModal">
    <view class="dialog-content" style="background: {{theme.card}};" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title" style="color: {{theme.textPrimary}};">调整信誉分</text>
        <text class="modal-close" bindtap="onCloseCreditModal" style="color: {{theme.textTertiary}};">×</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label" style="color: {{theme.textPrimary}};">用户：{{creditTargetUser.nickname || creditTargetUser.openid}}</text>
        </view>
        <view class="form-item">
          <text class="form-label" style="color: {{theme.textPrimary}};">当前信誉分：{{creditTargetUser.creditScore}}</text>
        </view>
        <view class="form-item">
          <text class="form-label" style="color: {{theme.textPrimary}};">调整值</text>
          <view class="credit-adjust-row">
            <view
              class="credit-sign-btn {{!creditIsNegative ? 'active' : ''}}"
              style="{{!creditIsNegative ? 'background:' + theme.primary + '; color:#fff; border-color:' + theme.primary + ';' : 'border-color:' + theme.border + '; color:' + theme.textSecondary + ';'}}"
              bindtap="onSetCreditSign"
              data-negative="{{false}}"
            >加分 +</view>
            <view
              class="credit-sign-btn {{creditIsNegative ? 'active' : ''}}"
              style="{{creditIsNegative ? 'background:' + theme.error + '; color:#fff; border-color:' + theme.error + ';' : 'border-color:' + theme.border + '; color:' + theme.textSecondary + ';'}}"
              bindtap="onSetCreditSign"
              data-negative="{{true}}"
            >扣分 −</view>
          </view>
          <input
            class="form-input credit-amount-input"
            type="digit"
            placeholder="请输入分数"
            value="{{creditChangeAbs}}"
            bindinput="onCreditAmountInput"
            adjust-position="{{true}}"
            cursor-spacing="120"
            style="background: {{theme.background}}; color: {{theme.textPrimary}};"
          />
          <text class="form-hint" style="color: {{theme.textTertiary}};">先选加分或扣分，再输入具体分数</text>
        </view>
        <view class="form-item">
          <text class="form-label" style="color: {{theme.textPrimary}};">原因</text>
          <input class="form-input" placeholder="请输入调整原因（必填）" value="{{creditReason}}" bindinput="onCreditReasonInput" adjust-position="{{true}}" cursor-spacing="80" style="background: {{theme.background}}; color: {{theme.textPrimary}};" />
        </view>
        <view class="form-item">
          <text class="form-label" style="color: {{theme.textPrimary}};">预估结果：<text style="color: {{theme.primary}}; font-weight: bold;">{{creditPreview}}</text></text>
        </view>
      </view>
      <view class="modal-footer">
        <view class="btn-cancel" bindtap="onCloseCreditModal" style="border-color: {{theme.border}}; color: {{theme.textSecondary}};">
          取消
        </view>
        <view class="btn-confirm" bindtap="onConfirmCreditChange">
          确认调整
        </view>
      </view>
    </view>
  </view>
</view>
