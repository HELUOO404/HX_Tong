/* pages/admin/user-edit.wxss */
.page {
  min-height: 100%;
  padding-bottom: 40rpx;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 30rpx;
  border: 4rpx solid #f0f0f0;
}

.avatar-btn {
  padding: 16rpx 40rpx;
  border-radius: 30rpx;
  color: #fff;
  font-size: 28rpx;
}

.form-section {
  padding: 20rpx 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  color: #333;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.permission-section {
  margin-top: 0;
}

.section-label {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  overflow: hidden;
  word-break: break-all;
  overflow-wrap: break-word;
}

.tag-item:active {
  opacity: 0.7;
}

.tag-checked {
  font-weight: 500;
}

.tag-role {
  font-size: 22rpx;
  margin-left: 8rpx;
  opacity: 0.8;
}

.tag-empty {
  padding: 32rpx 0;
  text-align: center;
  font-size: 26rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-tip {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

.tag-select-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 10rpx 0;
}

.tag-select-item {
  padding: 12rpx 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tag-select-item.active {
  border-color: #1677ff;
  color: #1677ff;
  background: #e6f4ff;
}

.tag-check {
  font-size: 24rpx;
  font-weight: bold;
}

.btn-section {
  padding: 40rpx 30rpx;
}

.btn-save {
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.btn-cancel {
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: 2rpx solid;
  box-sizing: border-box;
}
