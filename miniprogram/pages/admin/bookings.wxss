/* pages/admin/bookings.wxss */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background-color: var(--bg-primary);
}

/* 标签栏 */
.tab-bar {
  display: flex;
  padding: 0 20rpx;
  border-bottom: 1rpx solid var(--border-color);
  margin-bottom: 20rpx;
  background-color: var(--bg-white);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  position: relative;
  color: var(--text-secondary);
}

.tab-item.active {
  font-weight: 500;
  color: var(--primary-color);
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background-color: var(--primary-color);
}

/* 统计栏 */
.stats-bar {
  padding: 20rpx 30rpx;
  font-size: 26rpx;
  margin-bottom: 20rpx;
  color: var(--text-secondary);
}

/* 预约列表 */
.booking-list {
  padding: 0 30rpx;
}

.booking-card {
  border-radius: var(--border-radius-lg);
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid transparent;
  background-color: var(--bg-white);
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.2s ease;
}

.booking-card:active {
  box-shadow: var(--shadow-md);
}

.room-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.room-name {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  word-break: break-all;
  overflow-wrap: break-word;
  flex: 1;
  min-width: 0;
}

.status-badge {
  font-size: 24rpx;
  font-weight: 500;
}

/* 预约详情 */
.booking-detail {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  width: 120rpx;
  flex-shrink: 0;
  color: var(--text-secondary);
}

.info-row text:last-child {
  font-size: 26rpx;
  flex: 1;
  min-width: 0;
  word-break: break-all;
  overflow-wrap: break-word;
  color: var(--text-primary);
}

/* 操作按钮 */
.action-btns {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-light);
}

.btn-reject, .btn-approve {
  padding: 16rpx 40rpx;
  border-radius: var(--border-radius-md);
  font-size: 28rpx;
  font-weight: 500;
}

.btn-reject {
  border: 2rpx solid var(--error-color);
  color: var(--error-color);
  background-color: transparent;
}

.btn-approve {
  background: var(--primary-gradient);
  color: var(--bg-white);
}

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-state text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 加载中 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
