/* pages/admin/permission-tags.wxss */
.page {
  min-height: 100%;
  padding-bottom: 40rpx;
}

/* 头部 */
.header-bar {
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.header-desc {
  display: block;
  font-size: 26rpx;
}

/* 添加按钮 */
.add-section {
  padding: 0 30rpx 20rpx;
}

.add-btn {
  display: inline-flex;
  align-items: center;
  padding: 20rpx 40rpx;
  border-radius: 12rpx;
  color: #fff;
  font-size: 30rpx;
}

.add-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 标签列表 */
.tag-list {
  padding: 0 30rpx;
}

.tag-card {
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid transparent;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tag-info {
  flex: 1;
  min-width: 0;
}

.tag-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.tag-name {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 500;
  margin-right: 20rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.tag-desc {
  font-size: 26rpx;
  display: block;
  word-break: break-all;
  overflow-wrap: break-word;
  min-width: 0;
}

.tag-actions {
  display: flex;
  gap: 24rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 64rpx;
  min-height: 88rpx;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-state text {
  font-size: 28rpx;
}

.empty-tip {
  font-size: 24rpx;
  margin-top: 16rpx;
}

/* 加载中 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.tag-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 1001;
}

.tag-modal.show {
  transform: translateY(0);
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 36rpx;
}

.modal-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
  height: 0;
  box-sizing: border-box;
}

.modal-scroll-inner {
  padding: 30rpx 32rpx;
  box-sizing: border-box;
}

.form-item {
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 0;
  flex: 1;
  min-width: 0;
}

.form-label-row + .form-input {
  margin-top: 0;
}

.form-item > .form-label {
  margin-bottom: 12rpx;
}

.form-input, .form-picker {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-picker .arrow {
  font-size: 20rpx;
}

.form-tip {
  display: block;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1;
  margin: 0;
  padding: 0;
  border: none;
}

.btn-cancel {
  background: transparent;
  border: 2rpx solid !important;
}

.btn-cancel::after {
  border: none;
}

.btn-confirm {
  color: #fff;
}

.btn-confirm::after {
  border: none;
}

/* 标签角色徽章 */
.tag-role-badge {
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.tag-perm-info {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 字符计数 */
.char-count {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

/* 表单提示文字 */
.form-hint {
  display: block;
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

/* 角色选择器 */
.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  border: 2rpx solid;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-arrow {
  font-size: 22rpx;
}

/* 权限分组 */
.permission-groups {
  margin-top: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.perm-group {
  margin-bottom: 24rpx;
}

.perm-group-title {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
}

.perm-item {
  display: flex;
  align-items: center;
  padding: 16rpx 8rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.perm-checkbox {
  width: 44rpx;
  height: 44rpx;
  min-width: 44rpx;
  border: 3rpx solid;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.perm-checkbox.checked {
  border-color: transparent;
}

.check-mark {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.perm-text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.perm-label {
  display: block;
  font-size: 28rpx;
  line-height: 1.4;
  word-break: break-all;
  overflow-wrap: break-word;
}

.perm-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  margin-top: 4rpx;
  word-break: break-all;
  overflow-wrap: break-word;
}

/* 空状态文本 */
.empty-text {
  font-size: 28rpx;
}

.btn-confirm {
  color: #fff;
}
