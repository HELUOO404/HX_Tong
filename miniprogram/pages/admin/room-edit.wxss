.room-edit-container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 180rpx;
  background-color: var(--bg-primary);
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section {
  border-radius: var(--border-radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  background-color: var(--bg-white);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
  color: var(--text-primary);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  line-height: 88rpx;
}

.textarea-input {
  min-height: 160rpx;
  text-align: left;
  line-height: 1.6;
  padding: 24rpx;
}

.capacity-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.capacity-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.capacity-input {
  text-align: center;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.capacity-label {
  font-size: 24rpx;
  text-align: center;
}

.capacity-separator {
  font-size: 36rpx;
  font-weight: bold;
  margin-top: -20rpx;
}

.time-picker-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.time-picker-item {
  flex: 1;
}

.time-picker-value {
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.time-separator {
  font-size: 36rpx;
  font-weight: bold;
}

.picker-display {
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-item.is-default {
  border: 4rpx solid var(--primary-color);
}

.image-actions {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: rgba(0, 0, 0, 0.6);
  padding: 8rpx;
}

.image-action-btn {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #fff;
  padding: 8rpx 0;
}

.image-action-btn:first-child {
  border-right: 1rpx solid rgba(255, 255, 255, 0.3);
}

.default-badge {
  position: absolute;
  top: 0;
  right: 0;
  background: var(--primary-color);
  color: var(--bg-white);
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 0 0 0 12rpx;
}

.image-item.add-btn {
  border: 2rpx dashed #ddd;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.add-icon {
  font-size: 60rpx;
  color: #666;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.facility-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.facility-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 12rpx;
}

.facility-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.facility-name {
  font-size: 28rpx;
  font-weight: 500;
  word-break: break-all;
  overflow-wrap: break-word;
}

.facility-type {
  font-size: 24rpx;
}

.facility-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  font-size: 28rpx;
  padding: 8rpx 16rpx;
}

.resource-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.resource-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 12rpx;
  gap: 16rpx;
}

.resource-item.selected {
  background: rgba(24, 144, 255, 0.1);
}

.resource-name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  word-break: break-all;
  overflow-wrap: break-word;
}

.resource-type {
  font-size: 24rpx;
  margin-right: 16rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.empty-state {
  padding: 40rpx 0;
  text-align: center;
  font-size: 28rpx;
}

.add-btn {
  font-size: 28rpx;
}

.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: var(--bg-white);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  opacity: 0.7;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.facility-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 1001;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.facility-modal.show {
  transform: translateY(0);
}

.modal-content {
  padding: 32rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
  text-align: center;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-btn::after {
  border: none;
}