.approval-detail-container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 180rpx;
  background-color: var(--bg-primary);
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-card {
  border-radius: var(--border-radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  background-color: var(--bg-white);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.credit-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.credit-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
}

.credit-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.default-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.user-phone {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.room-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.room-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.room-location {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.booking-details {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 16rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.detail-label {
  font-size: 28rpx;
  flex-shrink: 0;
  color: var(--text-secondary);
}

.detail-value {
  font-size: 28rpx;
  text-align: right;
  flex: 1;
  margin-left: 24rpx;
  color: var(--text-primary);
}

.purpose-row {
  flex-direction: column;
  gap: 8rpx;
}

.purpose-text {
  text-align: left;
  background-color: var(--bg-gray);
  padding: 16rpx;
  border-radius: var(--border-radius-md);
  line-height: 1.5;
  color: var(--text-primary);
}

.reject-reason {
  font-size: 28rpx;
  line-height: 1.5;
  margin-top: 16rpx;
  display: block;
  color: var(--text-primary);
}

.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: var(--bg-white);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.action-section.readonly {
  justify-content: center;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.btn::after {
  border: none;
}

.btn-approve {
  flex: 1.5;
}

.status-tag {
  padding: 20rpx 60rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.reject-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 1001;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  background-color: var(--bg-white);
}

.reject-modal.show {
  transform: translateY(0);
}

.modal-content {
  padding: 32rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
  text-align: center;
  color: var(--text-primary);
}

.reject-input {
  width: 100%;
  height: 200rpx;
  padding: 24rpx;
  border-radius: var(--border-radius-md);
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  background-color: var(--bg-gray);
  color: var(--text-primary);
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-btn::after {
  border: none;
}