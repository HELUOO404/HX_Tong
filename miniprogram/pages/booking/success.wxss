.success-container {
  min-height: 100vh;
  background-color: var(--bg-primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
  box-sizing: border-box;
}

.success-icon {
  margin-bottom: 48rpx;
}

.success-title {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.success-desc {
  font-size: 30rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 80rpx;
}

.action-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.primary-btn {
  width: 100%;
  height: 96rpx;
  background: var(--primary-gradient);
  color: var(--bg-white);
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-btn::after {
  border: none;
}

.secondary-btn {
  width: 100%;
  height: 96rpx;
  background-color: var(--bg-white);
  color: var(--text-primary);
  font-size: 32rpx;
  border-radius: 48rpx;
  border: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
}

.secondary-btn::after {
  border: none;
}
