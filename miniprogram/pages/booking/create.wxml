<view class="booking-create-container" style="background-color: {{theme.background}};">
  <view class="room-card" style="background-color: {{theme.card}};">
    <view class="room-header">
      <text class="room-name" style="color: {{theme.textPrimary}};">{{roomInfo.name}}</text>
      <text class="room-location" style="color: {{theme.textSecondary}};">{{roomInfo.location}}</text>
    </view>
    <view class="room-info-row">
      <view class="info-item">
        <image class="info-icon" src="/assets/images/icons/user.png" mode="aspectFit"/>
        <text style="color: {{theme.textSecondary}};">
          <text wx:if="{{roomInfo.capacity && roomInfo.capacity.min !== undefined}}">{{roomInfo.capacity.min}}-{{roomInfo.capacity.max}}人</text>
          <text wx:elif="{{roomInfo.capacity > 0}}">{{roomInfo.capacity}}人</text>
          <text wx:else>未知容量</text>
        </text>
      </view>
      <view class="info-item">
        <image class="info-icon" src="/assets/images/icons/time.png" mode="aspectFit"/>
        <text style="color: {{theme.textSecondary}};">{{roomInfo.openTime}}-{{roomInfo.closeTime}}</text>
      </view>
    </view>
    <view wx:if="{{creditScore < 80}}" class="credit-warning" style="background-color: {{theme.error}}15; color: {{theme.error}};">
      信誉分不足（当前{{creditScore}}分），无法预约
    </view>
  </view>

  <view class="form-section" style="background-color: {{theme.card}};">
    <view class="form-item">
      <text class="form-label" style="color: {{theme.textPrimary}};">预约日期</text>
      <view wx:if="{{datePickerReady}}" class="picker-value" style="background-color: {{theme.background}}; color: {{theme.textPrimary}};" bindtap="onShowCalendar">
        <image class="picker-icon" src="/assets/images/icons/calendar.png" mode="aspectFit"/>
        <text>{{selectedDate}}</text>
        <image class="picker-arrow" src="/assets/images/icons/arrow-down.png" mode="aspectFit"/>
      </view>
      <view wx:else class="picker-value" style="background-color: {{theme.background}}; color: {{theme.textSecondary}};">
        <image class="picker-icon" src="/assets/images/icons/calendar.png" mode="aspectFit"/>
        <text>加载中...</text>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label" style="color: {{theme.textPrimary}};">选择时段</text>
      <view class="slot-legend">
        <view class="legend-item"><view class="legend-dot" style="background-color: {{theme.success}};"></view><text style="color: {{theme.textSecondary}};">可预约</text></view>
        <view class="legend-item"><view class="legend-dot" style="background-color: {{theme.warning}};"></view><text style="color: {{theme.textSecondary}};">待审批</text></view>
        <view class="legend-item"><view class="legend-dot" style="background-color: {{theme.error}};"></view><text style="color: {{theme.textSecondary}};">已预约</text></view>
      </view>
      <view class="time-selection-hint {{selectingEnd ? 'hint-end' : (startTime && endTime ? 'hint-complete' : (noSlotsToday ? 'hint-no-slots' : 'hint-start'))}}">
      <text wx:if="{{!startTime && noSlotsToday}}">今日无可预约时间</text>
      <text wx:elif="{{!startTime}}">请点击选择开始时段</text>
      <text wx:elif="{{!endTime}}">已选开始: {{startTime}}，请点击结束时段</text>
      <text wx:else>已选: {{startTime}} - {{endTime}}</text>
      <text class="hint-duration" wx:if="{{startTime && endTime}}" style="color: {{theme.primary}};">{{durationText}}</text>
    </view>
      <view class="time-slot-grid">
        <view
          wx:for="{{timeSlots}}"
          wx:key="startTime"
          class="time-slot {{item.inRange ? 'slot-in-range' : (item.available ? 'slot-available' : (item.slotStatus === 'pending' ? 'slot-pending' : 'slot-occupied'))}}"
          data-start="{{item.startTime}}"
          data-end="{{item.endTime}}"
          data-available="{{item.available}}"
          data-status="{{item.slotStatus}}"
          bindtap="onSlotTap"
        >
          <text class="slot-time">{{item.label}}</text>
          <text class="slot-status" wx:if="{{!item.available}}">{{item.slotStatus === 'pending' ? '待审批' : '已约'}}</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label" style="color: {{theme.textPrimary}};">公共资源（可选）</text>
      <view class="resource-list" wx:if="{{publicResources.length > 0}}">
        <view
          wx:for="{{publicResources}}"
          wx:key="_id"
          class="resource-item {{item.selected ? 'resource-selected' : (item.available ? '' : 'resource-unavailable')}} {{!startTime || !endTime ? 'resource-disabled' : ''}}"
          style="background-color: {{item.selected ? theme.primary + '15' : theme.background}}; border-color: {{item.selected ? theme.primary : (item.available ? theme.border : '#f0f0f0')}};"
          data-id="{{item._id}}"
          bindtap="onTogglePublicResource"
        >
          <view class="resource-info">
            <view class="resource-name-row">
              <text class="resource-name" style="color: {{item.selected ? theme.primary : (item.available ? theme.textPrimary : theme.textTertiary)}};">{{item.name}}</text>
              <text class="resource-qty" style="color: {{item.availableInPeriod > 0 ? theme.textSecondary : theme.error}};">
                <text wx:if="{{item.hasTimeFilter}}">可约: {{item.availableInPeriod}}/{{item.totalQuantity}}</text>
                <text wx:else>共{{item.totalQuantity}}个</text>
              </text>
            </view>
            <text wx:if="{{item.description}}" class="resource-desc">{{item.description}}</text>
          </view>
          <view wx:if="{{item.selected}}" class="resource-check">✓</view>
        </view>
      </view>
      <view class="resource-empty" wx:else>
        <text style="color: {{theme.textTertiary}}; font-size: 26rpx;">{{resourceEmptyReason || '暂无可用的公共资源'}}</text>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label" style="color: {{theme.textPrimary}};">会议主题 *</text>
      <textarea
        class="text-input textarea-input"
        maxlength="200"
        auto-height
        placeholder="请输入会议主题（至少5个字）"
        placeholder-style="color: {{theme.textTertiary}};"
        value="{{purpose}}"
        bindinput="onPurposeInput"
        style="background-color: {{theme.background}}; color: {{theme.textPrimary}};"
      />
    </view>

    <view class="form-item">
      <text class="form-label" style="color: {{theme.textPrimary}};">参与人数 *</text>
      <input
        class="text-input"
        type="number"
        placeholder="请输入预估人数"
        placeholder-style="color: {{theme.textTertiary}};"
        value="{{attendees}}"
        bindinput="onAttendeesInput"
        style="background-color: {{theme.background}}; color: {{theme.textPrimary}};"
      />
    </view>

    <view class="form-item">
      <view class="form-label form-label-icon-row">
        <image class="form-label-icon" src="/assets/images/icons/phone.png" mode="aspectFit"/>
        <text class="form-label-required" style="color: {{theme.textPrimary}};">*</text>
      </view>
      <input
        class="text-input"
        type="number"
        placeholder="请输入11位数"
        placeholder-style="color: {{theme.textTertiary}};"
        value="{{contactPhone}}"
        bindinput="onPhoneInput"
        maxlength="11"
        style="background-color: {{theme.background}}; color: {{theme.textPrimary}};"
      />
    </view>

    <!-- 日历选择弹层 -->
    <view class="calendar-mask {{showCalendar ? 'show' : ''}}" bindtap="onCloseCalendar"></view>
    <view class="calendar-popup {{showCalendar ? 'show' : ''}}" style="background-color: {{theme.card}};">
      <view class="calendar-header">
        <view class="calendar-nav-btn" bindtap="onPrevMonth">
          <text class="calendar-nav-arrow" style="color: {{theme.textSecondary}};">‹</text>
        </view>
        <text class="calendar-title" style="color: {{theme.textPrimary}};">{{calendarYear}}年{{calendarMonth}}月</text>
        <view class="calendar-nav-btn" bindtap="onNextMonth">
          <text class="calendar-nav-arrow" style="color: {{theme.textSecondary}};">›</text>
        </view>
      </view>
      <view class="calendar-weekdays">
        <text wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this" class="calendar-weekday" style="color: {{theme.textTertiary}};">{{item}}</text>
      </view>
      <view class="calendar-days" bindtouchstart="onCalendarTouchStart" bindtouchend="onCalendarTouchEnd">
        <view
          wx:for="{{calendarDays}}"
          wx:key="date"
          class="calendar-day {{item.isCurrentMonth ? '' : 'other-month'}} {{item.isToday ? 'today' : ''}} {{item.isSelectable ? 'selectable' : ''}} {{item.isSelected ? 'selected' : ''}} {{item.availability === 'partial' ? 'availability-partial' : ''}} {{item.availability === 'full' ? 'availability-full' : ''}}"
          style="{{item.isSelected ? 'border-color: ' + theme.primary + '; color: #fff; background-color: ' + theme.primary + ';' : ''}}"
          data-date="{{item.date}}"
          data-selectable="{{item.isSelectable}}"
          data-availability="{{item.availability}}"
          bindtap="onCalendarDayTap"
        >
          <text class="calendar-day-text">{{item.day}}</text>
          <view
            wx:if="{{item.isToday}}"
            class="calendar-today-dot {{item.isSelected ? 'on-selected' : ''}}"
            style="background-color: {{item.isSelected ? '#fff' : theme.primary}};"
          ></view>
        </view>
      </view>
      <view class="calendar-footer">
        <text class="calendar-hint" style="color: {{theme.textTertiary}};">蓝框可选 · 黄框部分已约 · 红框已约满</text>
        <view class="calendar-close-btn" bindtap="onCloseCalendar" style="background-color: {{theme.primary}};">
          <text style="color: #fff;">确定</text>
        </view>
      </view>
    </view>
  </view>

  <view class="submit-section">
    <button
      class="submit-btn {{isSubmitting || !isTimeAvailable || creditScore < 80 ? 'disabled' : ''}}"
      bindtap="onSubmit"
      disabled="{{isSubmitting || !isTimeAvailable || creditScore < 80}}"
      style="background-color: {{isSubmitting || !isTimeAvailable || creditScore < 80 ? theme.textTertiary : theme.primary}};"
    >
      <text wx:if="{{!isSubmitting && isTimeAvailable && creditScore >= 80}}">提交预约</text>
      <text wx:elif="{{isSubmitting}}">提交中...</text>
      <text wx:elif="{{creditScore < 80}}">信誉分不足</text>
      <text wx:else>{{durationText}}</text>
    </button>
  </view>
</view>
