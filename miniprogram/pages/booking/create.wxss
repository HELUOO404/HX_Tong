.booking-create-container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 180rpx;
}

.room-card {
  border-radius: var(--border-radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  background-color: var(--bg-white);
}

.room-header {
  margin-bottom: 20rpx;
}

.room-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-location {
  font-size: 28rpx;
  margin-top: 8rpx;
  display: block;
  color: var(--text-secondary);
}

.room-info-row {
  display: flex;
  gap: 32rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
}

.info-icon {
  width: 32rpx;
  height: 32rpx;
}

.credit-warning {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.form-section {
  border-radius: var(--border-radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  background-color: var(--bg-white);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.picker-icon {
  width: 32rpx;
  height: 32rpx;
}

.picker-arrow {
  width: 24rpx;
  height: 24rpx;
  margin-left: auto;
}

.slot-legend {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.time-slot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: flex-start;
}

.time-slot {
  width: calc(50% - 6rpx);
  min-width: calc(50% - 6rpx);
  max-width: calc(50% - 6rpx);
  padding: 20rpx 12rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 24rpx;
  border: 2rpx solid transparent;
  position: relative;
  box-sizing: border-box;
  overflow: hidden;
}

.slot-available {
  background-color: rgba(82, 196, 26, 0.12);
  border-color: rgba(82, 196, 26, 0.3);
  color: var(--success-color);
  transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
}

.slot-pending {
  background-color: rgba(250, 173, 20, 0.12);
  border-color: rgba(250, 173, 20, 0.3);
  color: var(--warning-color);
}

.slot-occupied {
  background-color: rgba(255, 77, 79, 0.12);
  border-color: rgba(255, 77, 79, 0.3);
  color: var(--error-color);
}

@keyframes firstSelectPulse {
  0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(24, 144, 255, 0.7); }
  35% { transform: scale(1.14); box-shadow: 0 0 0 20rpx rgba(24, 144, 255, 0); }
  70% { transform: scale(1.04); box-shadow: 0 0 0 0 rgba(24, 144, 255, 0); }
  100% { transform: scale(1); box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.25); }
}

.slot-in-range {
  background-color: rgba(24, 144, 255, 0.2);
  border-color: #1890FF;
  color: #1890FF;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.25);
  transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  animation: firstSelectPulse 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  animation-fill-mode: forwards;
}

.slot-in-range:active {
  transform: scale(0.96);
  transition: transform 0.1s;
}

.time-slot:active {
  transform: scale(0.95);
  opacity: 0.8;
  transition: all 0.15s ease;
}

.time-selection-hint {
  padding: 20rpx 24rpx;
  margin: 12rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.time-selection-hint.hint-start {
  background-color: rgba(24, 144, 255, 0.1);
  color: #1890FF;
}

.time-selection-hint.hint-end {
  background-color: rgba(250, 173, 20, 0.1);
  color: #FAAD14;
  font-weight: 500;
}

.time-selection-hint.hint-complete {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52C41A;
  font-weight: 500;
}

.time-selection-hint.hint-no-slots {
  background-color: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.hint-duration {
  font-size: 24rpx;
  font-weight: 400;
  opacity: 0.9;
}

.slot-time {
  display: block;
  font-weight: 500;
  font-size: 24rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.slot-status {
  display: block;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.resource-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.resource-item {
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border: 2rpx solid;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-height: 80rpx;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.resource-name {
  font-size: 26rpx;
  font-weight: 500;
  word-break: break-all;
  line-height: 1.3;
}

.resource-qty {
  font-size: 22rpx;
  white-space: nowrap;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.resource-selected {
  box-shadow: 0 2rpx 12rpx rgba(24, 144, 255, 0.25);
}

.resource-unavailable {
  opacity: 0.5;
}

.text-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.textarea-input {
  height: 160rpx;
  padding: 24rpx;
  text-align: left;
  overflow-y: auto;
  word-break: break-all;
  max-height: 200rpx;
}

.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: var(--bg-white);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  color: var(--bg-white);
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  opacity: 0.7;
}

.resource-disabled {
  opacity: 0.4;
  pointer-events: none;
}

.resource-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.resource-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  line-height: 1.4;
  word-break: break-all;
}

/* 日历弹层遮罩 */
.calendar-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
  z-index: 998;
}

.calendar-mask.show {
  opacity: 1;
  visibility: visible;
}

/* 日历弹层 */
.calendar-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 999;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.calendar-popup.show {
  transform: translateY(0);
}

/* 日历头部 */
.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.calendar-nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.calendar-nav-btn:active {
  background-color: rgba(0, 0, 0, 0.05);
}

.calendar-nav-arrow {
  font-size: 32rpx;
  font-weight: bold;
}

.calendar-title {
  font-size: 32rpx;
  font-weight: 600;
}

/* 星期标题 */
.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 16rpx;
}

.calendar-weekday {
  text-align: center;
  font-size: 24rpx;
  padding: 12rpx 0;
}

/* 日期网格 */
.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.calendar-day {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  position: relative;
  transition: all 0.15s ease;
}

.calendar-day-text {
  font-size: 28rpx;
  line-height: 1;
}

.calendar-today-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-top: 6rpx;
}

/* 其他月份的日期（灰色弱化） */
.calendar-day.other-month .calendar-day-text {
  opacity: 0.3;
}

/* 可选日期：蓝色边框 + 蓝色文字 */
.calendar-day.selectable {
  border: 2rpx solid #1890FF;
  color: #1890FF;
}

.calendar-day.selectable:active {
  background-color: rgba(24, 144, 255, 0.1);
}

/* 选中日期：蓝色边框 + 蓝色文字 */
.calendar-day.selected {
  border: 2rpx solid #1890FF;
  color: #1890FF;
  font-weight: 600;
  background-color: rgba(24, 144, 255, 0.08);
}

/* 不可选日期：灰色文字 */
.calendar-day:not(.selectable):not(.other-month) {
  color: #CCCCCC;
}

.calendar-day:not(.selectable):not(.other-month):active {
  transform: none;
}

/* 日历底部 */
.calendar-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #E8E8E8;
}

.calendar-hint {
  font-size: 24rpx;
}

.calendar-close-btn {
  padding: 16rpx 48rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.calendar-close-btn:active {
  opacity: 0.8;
}
