.booking-detail-container {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding: 24rpx;
  padding-bottom: 48rpx;
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 状态卡片 */
.status-card {
  background-color: var(--bg-white);
  border-radius: var(--border-radius-lg);
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.status-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  background-color: #F5F5F5;
}

.status-icon.status-pending {
  background-color: var(--warning-color);
}

.status-icon.status-approved {
  background-color: var(--success-color);
}

.status-icon.status-completed {
  background-color: var(--primary-color);
}

.status-icon.status-rejected {
  background-color: var(--error-color);
}

.status-icon.status-cancelled {
  background-color: var(--text-tertiary);
}

.status-text {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  text-align: center;
  width: 100%;
}

.status-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 预约信息 */
.info-section {
  background-color: var(--bg-white);
  border-radius: var(--border-radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* 操作按钮 */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.cancel-btn {
  width: 100%;
  height: 88rpx;
  background-color: transparent;
  color: var(--error-color);
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 2rpx solid var(--error-color);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn::after {
  border: none;
}

.signin-btn {
  width: 100%;
  height: 88rpx;
  background: var(--primary-gradient);
  color: var(--bg-white);
  font-size: 30rpx;
  border-radius: var(--border-radius-md);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.signin-btn::after {
  border: none;
}

/* 空状态 */
.empty-container {
  padding: 120rpx 0;
}
