.reject-mask {
  position: fixed;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.45);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease, visibility 0.25s ease;
  z-index: 1000;
}

.reject-mask.show {
  opacity: 1;
  visibility: visible;
}

.reject-dialog {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.25s ease, visibility 0.25s ease;
  z-index: 1001;
}

.reject-dialog.show {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

.reject-panel {
  width: 100%;
  max-width: 620rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
}

.reject-title {
  display: block;
  padding: 40rpx 32rpx 24rpx;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  color: #1a1a1a;
}

.reject-input {
  display: block;
  width: calc(100% - 64rpx);
  min-height: 80rpx;
  max-height: 200rpx;
  margin: 0 32rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #333333;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.reject-placeholder {
  color: #bfbfbf;
}

.reject-quick {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx 8rpx;
}

.reject-quick-label {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 1.4;
}

.reject-quick-picker-wrap {
  flex: 1;
  min-width: 0;
}

.reject-quick-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  border: 1rpx solid #e8e8e8;
}

.reject-quick-picker:active {
  background-color: #ebebeb;
}

.reject-quick-value {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #333333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reject-quick-arrow {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #bfbfbf;
  line-height: 1;
}

.reject-actions {
  display: flex;
  margin-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.reject-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.reject-btn-cancel {
  color: #1a1a1a;
  border-right: 1rpx solid #f0f0f0;
}

.reject-btn-cancel:active {
  background-color: #fafafa;
}

.reject-btn-confirm {
  color: #1890ff;
  font-weight: 600;
}

.reject-btn-confirm:active {
  background-color: #f0f7ff;
}
